        <member name="M:User.API.Controllers.UsuarioController.Create(User.Application.Dtos.UserDtos.CreateUserDto)">
             <summary>
             Cria um novo usuário
             </summary>
             <remarks>
             Exemplo de request:
            
                 POST /api/users
                 {
                    "name": "teste",
                    "email": "teste@email.com"
                    "idade": 18
                    "celular": "51980578892"
                    "tipoPessoa": "pessoafisica"
                 }
             </remarks>
             <response code="201">Usuário criado com sucesso</response>
             <response code="400">Erro de validação</response>
        </member>
