    <members>
        <member name="T:User.API.Controllers.EnderecoController">
            <summary>
            Gerenciamento de endereços
            </summary>
        </member>
        <member name="M:User.API.Controllers.EnderecoController.Create(User.Application.Dtos.EnderecoDtos.CreateEnderecoDto)">
             <summary>
             Cria um novo endereço
             </summary>
             <remarks>
             <b>Observações:</b>
             <br/>
             - O endereço está sempre vinculado a um usuário
             - O sistema é exclusivo para o Brasil
            
             <br/><br/>
             <b>Exemplo de request:</b>
            
                 POST /api/enderecos
                 {
                    "userId": 0,
                    "rua": "Av Brasil",
                    "numero": "100",
                    "cidade": "Porto Alegre",
                    "estado": "RS"
                 }
             </remarks>
             <response code="201">Endereço criado com sucesso</response>
             <response code="400">Erro de validação</response>
        </member>
        <member name="M:User.API.Controllers.EnderecoController.GetById(System.Int32)">
            <summary>
            Retorna um endereço pelo ID
            </summary>
            <param name="id">ID do endereço</param>
            <response code="200">Endereço encontrado</response>
            <response code="404">Endereço não encontrado</response>
        </member>
        <member name="M:User.API.Controllers.EnderecoController.Update(User.Application.Dtos.EnderecoDtos.UpdateEnderecoDto)">
             <summary>
             Atualiza um endereço existente
             </summary>
             <remarks>
             <b>Exemplo de request:</b>
            
                 PUT /api/enderecos
                 {
                    "id": 1,
                    "rua": "Av Brasil",
                    "numero": "200",
                    "cidade": "Porto Alegre",
                    "estado": "RS"
                 }
             </remarks>
             <response code="200">Endereço atualizado com sucesso</response>
             <response code="404">Endereço não encontrado</response>
        </member>
        <member name="M:User.API.Controllers.EnderecoController.Delete(System.Int32)">
             <summary>
             Remove um endereço pelo ID
             </summary>
             <remarks>
             Exemplo:
            
                 DELETE /api/enderecos/1
             </remarks>
             <param name="id">ID do endereço</param>
             <response code="204">Endereço removido com sucesso</response>
             <response code="404">Endereço não encontrado</response>
        </member>
