  "paths": {
    "/api/enderecos": {
      "post": {
        "tags": [
          "Endereco"
        ],
        "summary": "Cria um novo endereço",
        "description": "<b>Observações:</b>\r\n\r\n\r\n             - O endereço está sempre vinculado a um usuário\r\n             - O sistema é exclusivo para o Brasil\r\n            \r\n             \r\n\r\n<b>Exemplo de request:</b>\r\n            \r\n                 POST /api/enderecos\r\n                 {\r\n                    \"userId\": 0,\r\n                    \"rua\": \"Av Brasil\",\r\n                    \"numero\": \"100\",\r\n                    \"cidade\": \"Porto Alegre\",\r\n                    \"estado\": \"RS\"\r\n                 }",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEnderecoDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEnderecoDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEnderecoDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Endereço criado com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/EnderecoDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnderecoDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnderecoDto"
                }
              }
            }
          },
          "400": {
            "description": "Erro de validação",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Endereco"
        ],
        "summary": "Atualiza um endereço existente",
        "description": "<b>Exemplo de request:</b>\r\n            \r\n                 PUT /api/enderecos\r\n                 {\r\n                    \"id\": 1,\r\n                    \"rua\": \"Av Brasil\",\r\n                    \"numero\": \"200\",\r\n                    \"cidade\": \"Porto Alegre\",\r\n                    \"estado\": \"RS\"\r\n                 }",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEnderecoDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEnderecoDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEnderecoDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Endereço atualizado com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/EnderecoDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnderecoDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnderecoDto"
                }
              }
            }
          },
          "404": {
            "description": "Endereço não encontrado",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
