  "components": {
    "schemas": {
      "CreateEnderecoDto": {
        "type": "object",
        "properties": {
          "usuarioId": {
            "type": "integer",
            "format": "int32"
          },
          "rua": {
            "type": "string",
            "nullable": true
          },
          "numero": {
            "type": "string",
            "nullable": true
          },
          "cidade": {
            "type": "string",
            "nullable": true
          },
          "estado": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "description": "Nome completo do usuário",
            "nullable": true
          },
          "idade": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "celular": {
            "type": "string",
            "nullable": true
          },
          "documento": {
            "type": "string",
            "description": "Documento conforme o TipoPessoa:\r\nCPF → 11 dígitos\r\nCNPJ → 14 dígitos",
            "nullable": true
          },
          "tipoPessoa": {
            "$ref": "#/components/schemas/TipoPessoa"
          },
          "endereco": {
            "$ref": "#/components/schemas/CreateEnderecoDto"
          }
        },
        "additionalProperties": false
      },
      "EnderecoDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "rua": {
            "type": "string",
            "nullable": true
          },
          "numero": {
            "type": "string",
            "nullable": true
          },
          "cidade": {
            "type": "string",
            "nullable": true
          },
          "estado": {
            "type": "string",
            "nullable": true
          },
          "usuarioId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "TipoPessoa": {
        "enum": [
          "PessoaFisica",
          "PessoaJuridica"
        ],
        "type": "string"
      },
      "TransferenciaRequestDto": {
        "type": "object",
        "properties": {
          "usuarioRemetenteId": {
            "type": "integer",
            "format": "int32"
          },
          "usuarioDestinatarioId": {
            "type": "integer",
            "format": "int32"
          },
          "valor": {
            "type": "number",
            "format": "double"
          },
          "chaveIdempotencia": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TransferenciaResponseDto": {
        "type": "object",
        "properties": {
          "transacaoId": {
            "type": "string",
            "format": "uuid"
          },
          "valor": {
            "type": "number",
            "format": "double"
          },
          "destinatario": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "dataHora": {
            "type": "string",
            "format": "date-time"
