                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Endereco"
        ],
        "summary": "Remove um endereço pelo ID",
        "description": "Exemplo:\r\n            \r\n    DELETE /api/enderecos/1",
