    "/api/transferencias": {
      "post": {
        "tags": [
          "Transferencias"
        ],
        "summary": "Realiza uma transferência entre usuários",
        "description": "<b>Observações:</b>\r\n\r\n\r\n             - O valor deve ser maior que zero\r\n             - Não é permitido transferir para si mesmo\r\n             - A chave de idempotência evita duplicidade\r\n            \r\n             \r\n\r\n<b>Exemplo de request:</b>\r\n            \r\n                 POST /api/transferencias\r\n                 {\r\n                    \"usuarioRemetenteId\": 1,\r\n                    \"usuarioDestinatarioId\": 2,\r\n                    \"valor\": 150.00,\r\n                    \"chaveIdempotencia\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\"\r\n                 }",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferenciaRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferenciaRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/TransferenciaRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transferência realizada com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TransferenciaResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferenciaResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferenciaResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Erro de validação",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
